{
  "name": "google-translate-api-secure",
  "version": "3.0.0",
  "description": "A secure, production-ready API for Google Translate with no unsafe eval",
  "type": "module",
  "main": "src/index.js",
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "start:prod": "node -e \"process.env.NODE_ENV='production'; import('./src/server.js').then(({ startServer }) => startServer())\"",
    "dev": "node --watch src/server.js",
    "test": "node --test src/test.js",
    "test:coverage": "node --test --experimental-test-coverage src/test.js",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "check": "npm run lint && npm run test && npm run security:audit",
    "security:audit": "npm audit --audit-level=moderate",
    "security:fix": "npm audit fix",
    "clean": "rimraf node_modules logs coverage .nyc_output",
    "clean:logs": "rimraf logs/*",
    "docker:build": "docker build -t translate-api:latest .",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/google-translate-api-secure.git"
  },
  "keywords": [
    "translate",
    "translator",
    "google",
    "translation",
    "api",
    "secure",
    "production",
    "es-modules",
    "nodejs"
  ],
  "author": {
    "name": "Your Name",
    "email": "your.email@example.com"
  },
  "license": "MIT",
  "dependencies": {
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "morgan": "^1.10.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "eslint": "^9.17.0",
    "rimraf": "^6.0.1"
  }
}
